+let rec is_msg_sender_exp : exp -> bool
+= function
+  | Lv (MemberAccess (Lv (Var (x,_)), "sender", _, _)) when BatString.equal x "msg" -> true
+  | Lv (Var (x,vinfo)) ->
+    BatString.equal x (fst msg_sender)
+    || (match vinfo.org with
+        | Some e -> is_msg_sender_exp e
+        | None -> false)
+  | Cast (_, e) -> is_msg_sender_exp e
+  | _ -> false
 
-let collect_queries : vformula -> Path.t -> stmt -> query list
-= fun vf path stmt ->
+let rec is_other_addr_exp : exp -> bool
+= function
+  | Lv (Var (_,vinfo)) as e ->
+    (is_address (get_type_exp e) && not (is_msg_sender_exp e))
+    || (match vinfo.org with
+        | Some e' -> is_other_addr_exp e'
+        | None -> false)
+  | Cast (_, e) -> is_other_addr_exp e
+  | e -> is_address (get_type_exp e) && not (is_msg_sender_exp e)
+
+let is_sender_addr_compare_exp : exp -> exp -> bool
+= fun e1 e2 ->
+  (is_msg_sender_exp e1 && is_other_addr_exp e2)
+  || (is_msg_sender_exp e2 && is_other_addr_exp e1)
+
+let rec has_sender_addr_compare_exp : exp -> bool
+= function
+  | BinOp (NEq, e1, e2, _) -> is_sender_addr_compare_exp e1 e2
+  | BinOp (_, e1, e2, _) -> has_sender_addr_compare_exp e1 || has_sender_addr_compare_exp e2
+  | UnOp (_, e, _) -> has_sender_addr_compare_exp e
+  | Cast (_, e) -> has_sender_addr_compare_exp e
+  | CondTemp (e1,e2,e3,_,_) ->
+    has_sender_addr_compare_exp e1
+    || has_sender_addr_compare_exp e2
+    || has_sender_addr_compare_exp e3
+  | AssignTemp (_, e, _) -> has_sender_addr_compare_exp e
+  | CallTemp (e,args,ethop,gasop,_) ->
+    has_sender_addr_compare_exp e
+    || List.exists has_sender_addr_compare_exp args
+    || BatOption.default false (BatOption.map has_sender_addr_compare_exp ethop)
+    || BatOption.default false (BatOption.map has_sender_addr_compare_exp gasop)
+  | Lv _ | Int _ | Real _ | Str _ | True | False | ETypeName _ | IncTemp _ | DecTemp _ -> false
+
+let has_sender_if_guard_before : Global.t -> Path.t -> stmt -> bool
+= fun global path target_stmt ->
+  let func = FuncMap.find (Path.get_fkey path) global.fmap in
+  let g = Lang.get_cfg func in
+  let same_stmt s1 s2 =
+    match s1, s2 with
+    | Call (_,_,_,_,_,loc1,id1), Call (_,_,_,_,_,loc2,id2) ->
+      id1 = id2
+      || (loc1.line = loc2.line && loc1.offset = loc2.offset && loc1.len = loc2.len)
+    | _ -> s1 = s2
+  in
+  let rec loop = function
+    | [] -> false
+    | node::tl ->
+      let stmt = find_stmt node g in
+      if same_stmt stmt target_stmt then false
+      else
+        (match stmt with
+         | Assume (e, loc) when loc <> dummy_loc ->
+           if has_sender_addr_compare_exp e then true else loop tl
+         | _ -> loop tl)
+  in
+  loop (Path.get_bp path)
+
