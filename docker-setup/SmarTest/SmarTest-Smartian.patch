+let init_deployer_if_cnstr : func -> vformula
+= fun func ->
+  if is_constructor func then
+    VAnd (VBinRel (VEq, VVar deployer, VVar msg_sender),
+          VBinRel (VEq, VVar deployer_called, VCond VFalse))
+  else VTrue
