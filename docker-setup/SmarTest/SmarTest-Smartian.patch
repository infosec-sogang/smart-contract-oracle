+let update_deployer_called : func -> vformula -> vformula
+= fun func vf ->
+  if is_constructor func then vf
+  else
+    let target = VVar deployer_called in
+    let replacement = rename target in
+    let vf' = rewrite_vf vf target replacement in
+    let new_val = Ite (VCond (VBinRel (VEq, VVar msg_sender, VVar deployer)), VCond VTrue, replacement) in
